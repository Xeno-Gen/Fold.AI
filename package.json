{
  "name": "fold.ai",
  "version": "0.3.3",
  "description": "Fold.AI",
  "main": "bin/server.js",
  "bin": {
    "fold.ai": "bin/cli.js",
    "fold-ai": "bin/cli.js"
  },
  "files": [
    "bin/cli.js",
    "dist/",
    "static/",
    "Plugin/",
    "com/",
    "config/",
    "config/.env.example"
  ],
  "scripts": {
    "build": "tsc && npm run build-vue && npm run copy-assets",
    "copy-assets": "node -e \"var fs=require('fs'),p=require('path'),root=process.cwd(),dirs=['static','Plugin','com','config'];dirs.forEach(function(d){var s=p.join(root,d),t=p.join(root,'dist',d);fs.cpSync(s,t,{recursive:true})});try{fs.unlinkSync(p.join(root,'dist','config','.env'))}catch(e){}\"",
    "start": "node dist/bin/server.js",
    "dev": "ts-node bin/server.ts",
    "prepublishOnly": "npm run build",
    "build-vue": "esbuild static/vue/app.ts --bundle --outfile=static/vue/app.js --format=iife --global-name=VueApp --alias:vue=vue/dist/vue.esm-bundler.js --define:__VUE_OPTIONS_API__=true --define:__VUE_PROD_DEVTOOLS__=false --define:__VUE_PROD_HYDRATION_MISMATCH_DETAILS__=false"
  },
  "keywords": [
    "ai",
    "chat",
    "llm",
    "openai",
    "anthropic",
    "claude",
    "deepseek",
    "self-hosted"
  ],
  "author": "Fold.AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Xeno-Gen/Fold.AI"
  },
  "engines": {
    "node": ">=16"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^2.1.1",
    "uuid": "^14.0.0",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/multer": "^2.1.0",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.1",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
